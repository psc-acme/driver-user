{
    "name": "psc-acme/driver-user",
    "description": "Package driver-user for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DriverUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "nette/utils": "^4.0",
        "symfony/lock": "^7.0",
        "psr/event-dispatcher": "^1.0",
        "brick/date-time": "^0.7.1",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}